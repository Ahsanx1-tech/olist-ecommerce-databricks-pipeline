{
  "datasets": [
    {
      "name": "top_categories_revenue",
      "displayName": "Top 10 Categories by Revenue",
      "queryLines": [
        "SELECT\n",
        "  category,\n",
        "  total_revenue\n",
        "FROM\n",
        "  workspace.olist_project.gold_category_performance\n",
        "ORDER BY\n",
        "  total_revenue DESC\n",
        "LIMIT 10"
      ],
      "catalog": "workspace",
      "schema": "olist_project"
    },
    {
      "name": "monthly_revenue",
      "displayName": "Monthly Revenue Trend",
      "queryLines": [
        "SELECT\n",
        "  DATE_TRUNC('MONTH', shipping_limit_date) as month,\n",
        "  SUM(price) as revenue\n",
        "FROM\n",
        "  workspace.olist_project.raw_orders\n",
        "WHERE\n",
        "  shipping_limit_date IS NOT NULL\n",
        "GROUP BY\n",
        "  DATE_TRUNC('MONTH', shipping_limit_date)\n",
        "ORDER BY\n",
        "  month"
      ],
      "catalog": "workspace",
      "schema": "olist_project"
    },
    {
      "name": "total_revenue",
      "displayName": "Total Revenue",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_revenue) as total_revenue\n",
        "FROM\n",
        "  workspace.olist_project.gold_category_performance"
      ],
      "catalog": "workspace",
      "schema": "olist_project"
    },
    {
      "name": "revenue_by_payment",
      "displayName": "Revenue by Payment Type",
      "queryLines": [
        "SELECT\n",
        "  payment_type,\n",
        "  SUM(payment_value) as revenue\n",
        "FROM\n",
        "  workspace.olist_project.silver_sales\n",
        "GROUP BY\n",
        "  payment_type\n",
        "ORDER BY\n",
        "  revenue DESC"
      ],
      "catalog": "workspace",
      "schema": "olist_project"
    }
  ],
